{
	// ------------------------------------------------------------------------
	// VS Code Settings
	// ------------------------------------------------------------------------
	"files.exclude": {
		"**/.DS_Store": true,
		"**/.git": true,
		"**/*.csproj.lscache": true,
		"**/*.csproj.user": true,
		"**/Thumbs.db": true
	},
	// ------------------------------------------------------------------------
	// AI Settings
	// ------------------------------------------------------------------------
	"chat.agentFilesLocations": {
		".agents/agents": true,
	},
	"chat.agentSkillsLocations": {
		".agents/skills": true,
	},
	"chat.hookFilesLocations": {
		".agents/hooks": true,
	},
	"chat.instructionsFilesLocations": {
		".agents/instructions": true,
	},
	"chat.promptFilesLocations": {
		".agents/prompts": true,
	},
	// ------------------------------------------------------------------------
	// .NET Settings
	// ------------------------------------------------------------------------
	"dotnet.defaultSolution": "HawsLabs.Analyzers.slnx",
	// ------------------------------------------------------------------------
	// Source Control Settings
	// ------------------------------------------------------------------------
	"github.copilot.chat.commitMessageGeneration.instructions": [
		{
			"file": ".agents/instructions/commit-message.instructions.md"
		}
	]
}